# Admin Password - used for logging into the admin panel
VITE_ADMIN_PASSWORD=your_secure_admin_password_here

# GitHub Personal Access Token - must have Contents and Actions write permissions
# Create at: https://github.com/settings/personal-access-tokens/new
# Scopes needed: contents:read/write, actions:read/write
VITE_GITHUB_PAT=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
